rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function autenticado() {
      return request.auth != null;
    }

    function miUsuario() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }

    function esAdmin() {
      return autenticado() && miUsuario().rol == 'admin';
    }

    // Acceso a un dispositivo: propio (permanente) o por un pase no vencido.
    function tieneAcceso(id) {
      let u = miUsuario();
      return id in u.get('dispositivos', [])
        || (id in u.get('accesos', {}) && u.accesos[id].expira > request.time);
    }

    // Cada vecino solo puede leer su propio perfil; el admin puede leer todos.
    // Nadie escribe desde la app: los perfiles los administran las Functions
    // (creación por el admin y canje de pases) o la consola de Firebase.
    match /usuarios/{uid} {
      allow get: if autenticado() && (request.auth.uid == uid || esAdmin());
      allow list: if esAdmin();
      allow write: if false;
    }

    // Un vecino solo puede leer los dispositivos que tiene asignados o
    // compartidos por un pase vigente.
    match /dispositivos/{id} {
      allow get: if autenticado() && (esAdmin() || tieneAcceso(id));
      allow list: if esAdmin();
      allow write: if false;

      // Config Tuya: las Functions la leen con Admin SDK; el admin puede
      // verla para editarla desde el panel. Nadie escribe desde el cliente.
      match /privado/{doc} {
        allow read: if esAdmin();
        allow write: if false;
      }
    }

    // Pases: los crea/canjea/revoca las Functions. El emisor (o el admin)
    // puede leer los suyos para listarlos y revocarlos.
    match /pases/{token} {
      allow read: if autenticado() && (esAdmin() || resource.data.por == request.auth.uid);
      allow write: if false;
    }

    // El log de auditoría lo escriben las Cloud Functions y lo lee solo el admin.
    match /registros/{id} {
      allow read: if esAdmin();
      allow write: if false;
    }

    // Catálogo de inmuebles del condominio. Lo crean, editan y asignan las
    // Functions (solo admin). Cualquier autenticado puede leerlo (lo usará el
    // selector de "Mi perfil" cuando se habilite la autoasignación).
    match /inmuebles/{id} {
      allow read: if autenticado();
      allow write: if false;
    }

    // Marca de tiempo del último correo de "olvidé mi clave" por cuenta, para
    // limitar los envíos. Solo lo tocan las Functions; nadie más lo lee, porque
    // delataría qué correos tienen cuenta.
    match /resets/{id} {
      allow read, write: if false;
    }
  }
}
